# Docker Hub image (khi push)
# DOCKER_IMAGE=yourdockerhub/mln111-api
# DOCKER_TAG=latest

# API - bat buoc khi chay container
ConnectionStrings__Database=Host=YOUR_HOST;Port=5432;Database=mln111;Username=USER;Password=PASS;SSL Mode=Require
Jwt__Key=your-production-jwt-secret-min-32-chars
OPENAI_API_KEY=sk-YOUR_KEY

# Tuy chon
Ai__Provider=OpenAI
Ai__Model=gpt-5-nano
Ai__ApiKey=
ENABLE_SWAGGER=true
Cors__AllowAnyOrigin=true

# Seed admin (lan dau)
Seed__AdminEmail=admin@mln111.local
Seed__AdminPassword=Admin@123456
Seed__AdminDisplayName=Admin MLN111

# Postgres local: docker compose --profile local-db up --build
# va dat ConnectionStrings__Database=Host=postgres;Port=5432;Database=mln111;Username=postgres;Password=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mln111
